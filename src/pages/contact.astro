---
import Base from "../layouts/Base.astro";
import profile from "../data/profile.json";
---

<Base title="Contact — André Carvalho" description="Entre em contato comigo">
  <section class="flex flex-col px-24 py-20 gap-4">
    <span class="font-mono text-xs text-accent-secondary">~ $ mail --to andre</span>
    <h1 class="font-heading text-5xl text-foreground-primary">Vamos conversar</h1>
    <p class="font-body text-base text-foreground-secondary max-w-lg">
      Me mande uma mensagem. Vou responder assim que possível.
    </p>
  </section>

  <section class="flex justify-center px-24 pb-20 gap-12">
    <form
      action="https://formspree.io/f/your-form-id"
      method="POST"
      class="flex flex-col gap-4 w-[480px]"
    >
      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-xs text-foreground-secondary">name</span>
        <input
          type="text" name="name" required autocomplete="name"
          class="w-full h-11 px-3 rounded-md bg-surface-card border border-border-subtle text-foreground-primary font-body text-sm outline-none focus:border-accent-primary transition-colors"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-xs text-foreground-secondary">email</span>
        <input
          type="email" name="email" required autocomplete="email"
          class="w-full h-11 px-3 rounded-md bg-surface-card border border-border-subtle text-foreground-primary font-body text-sm outline-none focus:border-accent-primary transition-colors"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-xs text-foreground-secondary">subject</span>
        <input
          type="text" name="subject" autocomplete="off"
          class="w-full h-11 px-3 rounded-md bg-surface-card border border-border-subtle text-foreground-primary font-body text-sm outline-none focus:border-accent-primary transition-colors"
        />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="font-mono text-xs text-foreground-secondary">message</span>
        <textarea
          name="message" required rows={6}
          class="w-full px-3 py-3 rounded-md bg-surface-card border border-border-subtle text-foreground-primary font-body text-sm outline-none focus:border-accent-primary transition-colors resize-vertical"
        ></textarea>
      </label>

      <div class="flex justify-end">
        <button
          type="submit"
          class="px-6 py-3 rounded-md bg-accent-primary text-white font-body text-sm font-medium cursor-pointer hover:opacity-90 transition-opacity"
        >
          Enviar mensagem
        </button>
      </div>
    </form>

    <div class="flex flex-col gap-6 w-[280px]">
      <a href={`mailto:${profile.email}`} class="font-mono text-sm text-accent-primary no-underline hover:underline">
        {profile.email}
      </a>
      <a href={`https://${profile.social.github}`} class="font-mono text-sm text-accent-warm no-underline hover:underline">
        {profile.social.github}
      </a>
      <a href={`https://${profile.social.twitter}`} class="font-mono text-sm text-accent-primary no-underline hover:underline">
        {profile.social.twitter}
      </a>
      <span class="font-mono text-sm text-foreground-secondary">
        {profile.location}
      </span>
    </div>
  </section>
</Base>
