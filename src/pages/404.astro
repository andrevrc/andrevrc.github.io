---
import Base from "../layouts/Base.astro";
---

<Base title="404 — André Carvalho">
  <section class="flex flex-col items-center justify-center gap-6 px-24 py-32 text-center">
    <span class="font-mono text-7xl text-accent-primary font-bold">404</span>
    <h1 class="font-heading text-3xl text-foreground-primary">Página não encontrada</h1>
    <p class="font-body text-base text-foreground-secondary max-w-md">
      O caminho que você procurou não existe. Talvez tenha sido movido ou removido.
    </p>
    <a
      href="/"
      class="px-6 py-3 rounded-md bg-accent-primary text-white font-body text-sm font-medium no-underline hover:opacity-90 transition-opacity"
    >
      Voltar ao início
    </a>
  </section>
</Base>
