---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = ["todos", "tech", "carreira", "security", "ai", "reflexao", "projetos"];
---

<Base title="Writing — André Carvalho" description="Textos sobre tecnologia, carreira e segurança">
  <section class="flex flex-col px-24 py-20 gap-4">
    <span class="font-mono text-xs text-accent-secondary">~ $ ls writing/</span>
    <h1 class="font-heading text-5xl text-foreground-primary">Textos e reflexões</h1>
    <p class="font-body text-base text-foreground-secondary max-w-lg">
      Coisas que escrevo sobre tecnologia, carreira e o que mais passar pela cabeça.
    </p>
  </section>

  <div class="flex justify-center gap-2 px-24 pb-8">
    {categories.map((cat) => (
      <span
        class="font-mono text-xs text-foreground-secondary hover:text-accent-primary transition-colors cursor-pointer"
        class:list={{ "text-accent-primary": cat === "todos" }}
      >
        {cat}
      </span>
    ))}
  </div>

  <section class="flex flex-col gap-4 px-24 pb-12">
    {allPosts.map((post) => <PostCard post={post} />)}
  </section>
</Base>
