---
const items = [
  {
    emoji: "📘",
    title: "Estudando alignment de IA",
    description: "Cursos, artigos e implementações práticas sobre segurança em sistemas inteligentes.",
  },
  {
    emoji: "🔒",
    title: "CTF & Security Research",
    description: "Resolvendo desafios de segurança e contribuindo com ferramentas open-source.",
  },
  {
    emoji: "⚡",
    title: "Full-stack AI tools",
    description: "Construindo aplicações que unem frontend, backend e modelos de linguagem.",
  },
  {
    emoji: "✍️",
    title: "Escrevendo mais",
    description: "Compromisso de publicar um artigo técnico por mês sobre tecnologia e carreira.",
  },
];
---

<section class="flex flex-col px-24 py-20 gap-8" id="now">
  <span class="font-mono text-xs text-accent-primary">
    ~ $ cat now.md
  </span>

  <h2 class="font-heading text-3xl text-foreground-primary">
    Agora
  </h2>

  <div class="flex flex-col gap-5 w-full">
    {items.map((item) => (
      <div class="flex gap-4 items-start">
        <span class="font-body text-lg text-accent-primary shrink-0">
          {item.emoji}
        </span>
        <div class="flex flex-col gap-1">
          <h3 class="font-heading text-lg text-foreground-primary">
            {item.title}
          </h3>
          <p class="font-body text-sm text-foreground-secondary">
            {item.description}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
