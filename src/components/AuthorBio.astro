---
import profile from "../data/profile.json";
---

<section class="flex justify-center px-24 py-12 bg-surface-primary">
  <div class="flex items-center gap-5 w-[720px]">
    <div class="size-16 rounded-full bg-accent-primary shrink-0" />
    <div class="flex flex-col gap-1 flex-1">
      <span class="font-heading text-lg text-foreground-primary">{profile.name}</span>
      <p class="font-body text-sm text-foreground-secondary">
        Full-stack developer, entusiasta de IA e segurança. Escrevendo sobre o que aprendo.
      </p>
    </div>
  </div>
</section>
